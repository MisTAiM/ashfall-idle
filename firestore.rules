// Firestore Security Rules for Ashfall Idle
// Deploy via Firebase Console > Firestore > Rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Player saves - ONLY the authenticated user can read/write their own save
    match /saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Player profiles - anyone can read (leaderboard), only owner can write
    match /players/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Bazaar - anyone can read listings, authenticated users can create
    match /bazaar/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.seller == request.auth.uid ||
        resource.data.status == 'active'
      );
    }
    // Bazaar gold - only the owner can read/write their pending gold
    match /bazaar_gold/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Guilds - authenticated users can read all, members can write
    match /guilds/{guildId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    // PvP queue/results
    match /pvp_queue/{docId} {
      allow read, write: if request.auth != null;
    }
    match /pvp_results/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    // Bounties
    match /bounties/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    // Leaderboard
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == docId;
    }
  }
}
