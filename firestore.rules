rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ADMIN CHECK ────────────────────────────────────────
    // Admin UID has full read/write/delete access everywhere
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'ndLiweJRdGbaqWIbPgIj0Izigez2';
    }

    // ── PLAYER SAVES ──────────────────────────────────────
    match /saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write, delete: if isAdmin();
    }

    // ── PLAYER PROFILES / LEADERBOARD ─────────────────────
    match /players/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow write, delete: if isAdmin();
    }

    // ── LEADERBOARD COLLECTION ────────────────────────────
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == docId;
      allow write, delete: if isAdmin();
    }

    // ── BAZAAR ────────────────────────────────────────────
    match /bazaar/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /bazaar_gold/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ── GUILDS ────────────────────────────────────────────
    match /guilds/{guildId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
      allow write, delete: if isAdmin();
    }

    // ── PVP ───────────────────────────────────────────────
    match /pvp_queue/{docId} {
      allow read, write: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /pvp_results/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }

    // ── BOUNTIES ──────────────────────────────────────────
    match /bounties/{docId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // ── SOCIAL ────────────────────────────────────────────
    match /friends/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /friend_requests/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /messages/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /inbox/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── ADMIN COLLECTIONS ────────────────────────────────
    match /admin_log/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    match /admin_bans/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /game_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
